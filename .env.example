# OnchainKit API Key (required for Base integration)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_api_key_here

# Privy Configuration (required for wallet authentication)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Supabase Configuration (required for database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Pinata Configuration (required for IPFS storage)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_here

# Farcaster/Neynar Configuration (required for social features)
NEYNAR_API_KEY=your_neynar_api_key_here

# Optional: Custom RPC URLs
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Optional: Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRAME_URL=http://localhost:3000/api/frame
